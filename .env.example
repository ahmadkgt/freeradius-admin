# Copy to .env in the project root and edit before running:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build

# --- MySQL ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password
MYSQL_DATABASE=radius
MYSQL_USER=radius
MYSQL_PASSWORD=CHANGE_ME_strong_db_password

# --- Backend ---
# Generate a long random secret with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Bootstrap admin (seeded once on first startup). After first login,
# change the password from inside the panel and remove this from the env.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=CHANGE_ME_initial_admin_password

# Comma-separated list of origins allowed by CORS. For an IP-only deploy
# behind the bundled nginx, the panel and API share the same origin so this
# only matters when the frontend dev server runs separately.
CORS_ORIGINS=http://localhost:8080
