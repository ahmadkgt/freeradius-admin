DATABASE_URL=mysql+pymysql://radius:radiuspass@localhost:3306/radius?charset=utf8mb4
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-please-set-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Bootstrap admin (seeded on first startup if no admin exists). Change after first login.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin
